#hier importieren wir tkinter und haben somit zugriff auf das Tool-Kit Tk
import tkinter as tk
from tkinter import ttk 
#pillow library importieren

#ImageTk ist die Schnittstelle zwischen Pillow und Tkinter
from PIL import Image, ImageTk
#import tkinter.font as tkFont

#testing window for tkinter
#tk._test()





#Labels sind Widgets in einer GUI, also ein baustein innerhalb meines Fensters.
#Buttons sind ebenfalls Widgets
#es gibt viele weitere Widgets in der tkinter library 

#how to create a GUI?

#create tk-object and safe it in variable (root)
root = tk.Tk()
#widget erstellen um inhalt in das fenster einzubauen
#title methode verändert den title des GUIs
root.title("Timer")

#hier finde ich die Bildschirmhöhe/Breite heraus
swidth = root.winfo_screenmmwidth()
sheight = root.winfo_screenheight()

#hier berechne ich die Fenstergröße im Verhälnis
width = int(swidth * 0.5)
height = int(sheight * 0.2)

#hier muss ich mit f-string ein integer in einen string umwandeln:
root.geometry(f'{width}x{height}')
root.minsize(width=200,height=100)
root.maxsize(width=500, height=400)
root.resizable(True, True)


img = Image.open("logo.png")
#hier wird das img zu einem in ein tkinter lesbares Format umgewandelt (PhotoImage). 
#PhotoImage ist eine von Pillow vor definierte Klasse
photo = ImageTk.PhotoImage(img)

img.show()
#root ist hier parent
#um später zugriff auf das label zu haben braucht es eine Variable (label1)
#text wird bisher nicht angezeigt weil layout fehlt, es benötigt die methode pack:
#pack ist ein layout manager, der Widgets im Hauptfenster organisiert, positioniert und ausrichtet
label1 = tk.Label(root, text="hello world!", bg='#00ff00')
label1.pack(side='top', expand=True, fill='y')

label2 = tk.Label(root, text='hallo welt!', bg='red')
label2.pack(side='top', expand=True, fill='y')

#mögliche side values: 'bottom', 'left', 'right'

#mithilfe von ttk widgets lässt sich das verhalten vom code und das erscheinungsbild eines Widgets besser
#trennen. Es ist nicht notwendig, aber oft sinnvoll, sobald der code komplexer wird.
#bei tk wird sowohl die funktion eines widges sowie dessen erscheinungsbild im widget selbst festgelegt
#siehe Z.65/68

#bei ttk wird beides seperat voneinander geschrieben:
#Widget:
label3 = ttk.Label(root, image=photo)

#Inhalt kann auch mithilfe der configure methode seperat stehen
#label3.configure(text='hallo welt!')

#Erscheinungsbild


label3.pack(side='top', expand=True, fill='y')



#hier wird eine Methode gestartet
#eventloop: prüft permanent, ob ein event auftritt
root.mainloop()

print("test")