import tkinter as tk
from tkinter import ttk
from PIL import Image, ImageTk
import tkinter.font as tkFont

root = tk.Tk()
root.resizable(True,True)


screenwidth = root.winfo_screenmmwidth()
screenheight= root.winfo_screenmmheight()

width = int(screenwidth * 0.7)
height = int(screenheight * 0.5)
root.geometry(f'{width}x{height}')
root.minsize(width=200, height=100)

image = Image.open('logo.png').resize((250,100))
photo = ImageTk.PhotoImage(image)

font = tkFont.Font(family= 'continua', size=60)

label1 = tk.Label(root, image=photo)
label1.pack(side='top', expand=True, fill='both')

# .keys listet die verfügbaren Funktionen auf.
# mithilfe dieser Looop können wir kontrollieren, welche Funktionen/Ooptionen bei Label1 verfügbar,
# und auch bereits verwendet werden
#kontrollschleife:
#for item in label1.keys():
#    print(item, ':', label1[item])

#Schlüsselschreibweise
#label1['image'] = photo
#configure Methode
#compund ist eine Property/ Label-Option mit der ich image und text gleichzeit anzeigen kann

label1.configure(text='hello \n world',bg='#00ff00', compound='center', font=font, fg='#ff00e4')

#--- programm start ---
root.mainloop()